generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  credits   Int      @default(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile?
  resumes Resume[]

  codeAnalyses CodeAnalysis[]
}

model Profile {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  skills     String[]
  targetRole String?
  experience String?
  about      String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id         Int    @id @default(autoincrement())
  resumeName String
  targetRole String

  atsScore   Int
  conclusion String

  skills     Int
  projects   Int
  experience Int
  formatting Int

  strengths    String[]
  improvements String[]

  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Complexity {
  LOW
  MEDIUM
  HIGH
}

model CodeAnalysis {
  id Int @id @default(autoincrement())

  title    String?
  language String
  code     String

  summary      String
  overallScore Int

  correctness     Int
  performance     Int
  readability     Int
  maintainability Int
  bestPractices   Int

  linesOfCode Int
  complexity  Complexity

  issues       String[]
  improvements String[]

  optimizedCode String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
